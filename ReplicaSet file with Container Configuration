Kubernetes YAML for ReplicaSet

apiVersion: apps/v1      # API Version
kind: ReplicaSet         # Resource type
metadata:
  name: nginx-rs         # ReplicaSet name
  labels:
    app: nginx

spec:
  replicas: 3            # Desired no. of pods

  selector:
    matchLabels:         # Selects Pods with label app = nginx
      app: nginx

  template:
    metadata:            # Pod template (Used to create new Pods)
      labels:
        app: nginx

    spec:
      containers:        # Container Configuration
      - name: nginx
        image: nginx:1.25
        ports:
        - containerPort: 80
